@import '../display/library/notifier/notifier.styl';

image-size = 42px;
menu-width = 154px;
// M3 Expressive — Chrome-native linear() springs (cf. input.styl tokens).
m3-emphasized-local = linear(0, 0.005, 0.018 1.5%, 0.066 3.7%, 0.171 7.5%, 0.346 13.6%, 0.547 21%, 0.722 29.4%, 0.853 38.4%, 0.937 47.7%, 0.978 56.8%, 0.997 67.4%, 1);
m3-spring-local = linear(0, 0.046 4%, 0.196 9%, 0.523 19%, 0.81 28%, 1.012 37%, 1.099 45%, 1.108 53%, 1.069 64%, 1.014 76%, 0.987 86%, 1);
motion-fast = 160ms m3-emphasized-local;
motion-standard = 220ms m3-emphasized-local;

/*
 * 划词翻译按钮样式
 */
#edge-translate-button {
    display: inline-block !important;
    width: menu-width !important;
    min-width: menu-width !important;
    max-width: menu-width !important;
    height: image-size !important;
    min-height: image-size !important;
    max-height: image-size !important;
    padding: 0 !important;
    margin: 0 !important;
    position: fixed !important;
    box-shadow: 0 12px 28px rgba(30, 47, 72, 0.16), 0 3px 10px rgba(30, 47, 72, 0.08), inset 0 1px 0 rgba(255, 255, 255, .82) !important;
    cursor: pointer !important;
    border-radius: 22px !important;
    z-index: 2147483647 !important;
    box-sizing: content-box !important;
    overflow: hidden !important;
    border: 1px solid rgba(255, 255, 255, .76) !important;
    backdrop-filter: none !important;
    -webkit-backdrop-filter: none !important;
    transition: box-shadow motion-standard, transform motion-standard, border-color motion-fast !important;
    animation: selection-toolbar-enter 220ms m3-spring-local !important;

    &:hover {
        box-shadow: 0 15px 32px rgba(30, 47, 72, 0.18), 0 0 0 4px rgba(26, 115, 232, 0.08), inset 0 1px 0 rgba(255, 255, 255, .9) !important;
        transform: translateY(-1px) scale(1.006) !important;
        border-color: rgba(211, 227, 253, .92) !important;
    }

    &:active {
        transform: translateY(0) scale(0.985) !important;
    }

    @keyframes selection-toolbar-enter {
        0% {
            opacity: 0;
            transform: translateY(5px) scale(0.98);
        }

        100% {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    @media (prefers-reduced-motion: reduce) {
        transition-duration: 1ms !important;
        animation-duration: 1ms !important;

        &:hover,
        &:active {
            transform: none !important;
        }
    }
}
