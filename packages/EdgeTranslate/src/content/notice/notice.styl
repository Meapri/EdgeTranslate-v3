@import '../display/library/notifier/notifier.styl'
@import '../../common/style/input.styl'

// ════════════════════════════════════════════════════════════════════════
// EdgeTranslate Notice page — iOS 26 Liquid Glass
//
// A long-scroll informational page (changelog / about / permissions).
// Same liquid glass app-window pattern as the options page.
// ════════════════════════════════════════════════════════════════════════

html,
body
    width: 100%
    min-height: 100%
    padding: 0
    margin: 0
    color: unquote('var(--ios-label-primary)')
    background: unquote('var(--ios-bg-grouped)')
    font-family: unquote('var(--ios-font-stack)')
    -webkit-font-smoothing: antialiased
    -moz-osx-font-smoothing: grayscale
    font-variant-ligatures: none
    font-weight: 400
    letter-spacing: -0.2px

body
    position: relative
    padding: 32px 16px
    box-sizing: border-box

// Ambient mesh — same iOS system-color radial blobs as popup/options.
body::before
    content: ''
    position: fixed
    inset: -40px
    z-index: 0
    pointer-events: none
    background: unquote('radial-gradient(120% 80% at 0% 0%, color-mix(in oklab, var(--ios-system-blue) 14%, transparent), transparent 56%), radial-gradient(120% 80% at 100% 100%, color-mix(in oklab, var(--ios-system-teal) 12%, transparent), transparent 60%)')

// ─── Glass app window ──────────────────────────────────────────────────
#notice
    position: relative
    z-index: 1
    width: 100%
    max-width: 920px
    margin: 0 auto
    padding: 0 0 28px
    overflow: hidden
    border: 0.5px solid unquote('var(--ios-glass-stroke)')
    border-radius: unquote('var(--ios-radius-3xl)')
    background: unquote('var(--ios-glass-thick)')
    backdrop-filter: unquote('var(--ios-glass-filter-thick)')
    -webkit-backdrop-filter: unquote('var(--ios-glass-filter-thick)')
    box-shadow: unquote('inset 0 1px 0 rgba(255,255,255,0.35), var(--ios-elev-floating)')

// ─── Header (sticky Liquid Glass toolbar) ──────────────────────────────
header
    position: sticky
    top: 0
    z-index: 4
    min-height: 76px
    padding: 16px 32px
    box-sizing: border-box
    display: flex
    align-items: center
    gap: 14px
    color: unquote('var(--ios-label-primary)')
    font-size: 22px
    font-weight: 700
    letter-spacing: -0.5px
    background: unquote('var(--ios-glass-regular)')
    backdrop-filter: unquote('var(--ios-glass-filter-regular)')
    -webkit-backdrop-filter: unquote('var(--ios-glass-filter-regular)')
    border-bottom: 0.5px solid unquote('var(--md-sys-color-outline-variant)')

header img
    width: 44px
    height: 44px
    border-radius: 12px
    box-shadow: unquote('var(--ios-elev-1)')

.space
    display: none

// ─── Content ───────────────────────────────────────────────────────────
h1
    margin: 28px 32px 12px
    color: unquote('var(--ios-label-primary)')
    font-size: 22px
    font-weight: 700
    letter-spacing: -0.4px
    line-height: 1.3

ol,
ul
    box-sizing: border-box
    color: unquote('var(--ios-label-primary)')
    font-size: 15px
    line-height: 1.65

ol
    margin: 0 32px 18px
    padding: 16px 20px 16px 42px
    background: unquote('var(--ios-fill-quaternary)')
    border-radius: unquote('var(--ios-radius-md)')

ul
    margin: 8px 0 0
    padding: 10px 12px 10px 30px
    background: unquote('var(--ios-fill-quaternary)')
    border-radius: unquote('var(--ios-radius-sm)')

li
    margin: 4px 0

a
    color: unquote('var(--ios-tint)')
    border-radius: 6px
    font-weight: 500
    text-decoration: none
    overflow-wrap: anywhere
    transition: background-color motion-state-fast, color motion-state-fast

a:hover
    background: unquote('color-mix(in oklab, var(--ios-tint) 12%, transparent)')
    text-decoration: underline

b
    color: unquote('var(--ios-label-primary)')
    font-weight: 600

// ─── Responsive ────────────────────────────────────────────────────────
@media (max-width: 640px)
    body
        padding: 0
    #notice
        min-height: 100vh
        border-radius: 0
        box-shadow: none
        border: 0
    header
        padding: 18px 20px
        font-size: 20px
    h1
        margin: 24px 20px 10px
        font-size: 18px
    ol
        margin: 0 20px 16px
        padding: 14px 16px 14px 34px
