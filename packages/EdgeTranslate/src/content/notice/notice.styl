material-primary = #0b57d0;
material-on-primary-container = #041e49;
material-on-surface = #1f1f1f;
material-muted = #5f6368;
material-outline = #e1e3e1;
material-surface = #ffffff;
material-background = #f8fafd;
material-container = #f1f4f8;
material-hover = rgba(11, 87, 208, 0.08);

html,
body {
	width: 100%;
	min-height: 100%;
	padding: 0;
	margin: 0;
	background:
		radial-gradient(circle at 18% 0, rgba(211, 227, 253, 0.7), transparent 28rem),
		material-background;
	color: material-on-surface;
	font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen, Ubuntu,
		Cantarell, "Helvetica Neue", Arial, sans-serif;
	-webkit-font-smoothing: antialiased;
	-moz-osx-font-smoothing: grayscale;
	font-variant-ligatures: none;
	font-weight: 400;
}

body {
	padding: 32px 16px;
	box-sizing: border-box;
}

#notice {
	width: 100%;
	max-width: 920px;
	margin: 0 auto;
	padding: 0 0 28px;
	background: material-surface;
	border-radius: 8px;
	box-shadow: 0 12px 30px rgba(60, 64, 67, 0.12), 0 3px 8px rgba(60, 64, 67, 0.08);
	overflow: hidden;
}

header {
	min-height: 72px;
	padding: 16px 28px;
	box-sizing: border-box;
	display: flex;
	align-items: center;
	gap: 14px;
	background: linear-gradient(180deg, #fff, material-background);
	border-bottom: 1px solid material-outline;
	color: material-on-surface;
	font-size: 24px;
	font-weight: 700;
	letter-spacing: 0;
}

header img {
	width: 40px;
	height: 40px;
	border-radius: 8px;
	box-shadow: 0 1px 2px rgba(60, 64, 67, 0.16);
}

.space {
	display: none;
}

h1 {
	margin: 28px 32px 12px;
	color: material-on-surface;
	font-size: 20px;
	font-weight: 700;
	letter-spacing: 0;
	line-height: 1.3;
}

ol,
ul {
	box-sizing: border-box;
	color: material-on-surface;
	font-size: 15px;
	line-height: 1.65;
}

ol {
	margin: 0 32px 18px;
	padding: 16px 20px 16px 42px;
	background: material-surface;
	border: 1px solid material-outline;
	border-radius: 8px;
}

ul {
	margin: 8px 0 0;
	padding: 10px 12px 10px 30px;
	background: material-container;
	border-radius: 8px;
}

li {
	margin: 4px 0;
}

a {
	color: material-primary;
	border-radius: 6px;
	font-weight: 600;
	text-decoration: none;
	overflow-wrap: anywhere;
}

a:hover {
	background: material-hover;
	text-decoration: underline;
}

b {
	color: material-on-primary-container;
	font-weight: 700;
}

@media (prefers-color-scheme: dark) {
	html,
	body {
		background: #15191d;
		color: #e8eaed;
	}

	#notice {
		background: #1b2026;
		box-shadow: 0 14px 32px rgba(0, 0, 0, 0.45), 0 3px 10px rgba(0, 0, 0, 0.34);
	}

	header {
		background: #20262d;
		border-bottom-color: #3d4651;
		color: #e8eaed;
	}

	h1,
	ol,
	ul {
		color: #e8eaed;
	}

	ol {
		background: #1b2026;
		border-color: #3d4651;
	}

	ul {
		background: #242a31;
	}

	a {
		color: #a8c7fa;
	}

	b {
		color: #d3e3fd;
	}
}

@media (max-width: 640px) {
	body {
		padding: 0;
	}

	#notice {
		min-height: 100vh;
		border-radius: 0;
		box-shadow: none;
	}

	header {
		padding: 18px 20px;
		font-size: 22px;
	}

	h1 {
		margin: 24px 20px 10px;
		font-size: 18px;
	}

	ol {
		margin: 0 20px 16px;
		padding: 14px 16px 14px 34px;
	}
}
