@import '../common/style/input.styl';

@font-face {
    font-family: 'translateIcon';
    src: url('~/iconfont.eot?t=1531409630632');
    src: url('~/iconfont.eot?t=1531409630632#iefix') format('embedded-opentype'), url('data:application/x-font-woff;charset=utf-8;base64,') format('woff'), url('~/iconfont.ttf?t=1531409630632') format('truetype'), url('~/iconfont.svg?t=1531409630632#iconfont') format('svg');
}

material-primary = #1a73e8;
material-on-surface = #202124;
material-muted = #5f6368;
material-outline = #dadce0;
material-background = #f8fafd;
material-hover = #f1f6fe;
motion-fast = 120ms cubic-bezier(0.2, 0, 0, 1);
motion-standard = 180ms cubic-bezier(0.2, 0, 0, 1);
motion-emphasized = 260ms cubic-bezier(0.2, 0, 0, 1);

html,
body,
input,
select,
button,
textarea {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen, Ubuntu,
        Cantarell, "Helvetica Neue", Arial, sans-serif;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    font-variant-ligatures: none;
    font-weight: 400;
}

.translate-icon {
    font-family: 'translateIcon' !important;
    font-size: 20px;
    font-style: normal;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
}

.translate-icon-exchange::before {
    content: '\e8f8';
}

.translate-icon-arrow-up::before {
    content: '\e695';
}

.translate-icon-arrow-down::before {
    content: '\e606';
}

html,
body {
    max-width: 420px;
    min-width: 360px;
    margin: 0;
    overflow: hidden;
    background: material-background;
    color: material-on-surface;
}

.frame {
    margin: 0;
    padding: 16px;
    background: #fff;
    transition: background-color motion-standard;
}

.row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 0 0 12px;
    line-height: 1.4;
}

.col {
    flex: 1 1 0;
}

.selection {
    display: flex;
    flex-direction: column;
}

.switch-label {
    color: material-on-surface;
    font-size: 14px;
}

select,
#translate_input {
    width: 100%;
    min-height: 40px;
    box-sizing: border-box;
    padding: 8px 12px;
    color: material-on-surface;
    background: #fff;
    border: 1px solid material-outline;
    border-radius: 8px;
    font-size: 14px;
    outline: none;
    transition: background-color motion-fast, box-shadow motion-fast, color motion-fast;
}

select:hover,
#translate_input:hover {
    background: material-hover;
}

select:focus,
#translate_input:focus {
    border-color: material-primary;
    box-shadow: 0 0 0 3px rgba(26, 115, 232, 0.12);
}

#translate_input {
    flex: 1 1 auto;
}

#translateSubmit {
    min-width: 88px;
    min-height: 40px;
    padding: 0 16px;
    color: #fff;
    background: material-primary;
    border: 1px solid material-primary;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: background-color motion-fast, box-shadow motion-fast, color motion-fast;
}

#translateSubmit:hover {
    background: #185abc;
    box-shadow: 0 1px 2px rgba(60, 64, 67, 0.2);
}

#hint_message {
    display: none;
    margin: 2px 0 12px;
    color: #d93025;
    font-size: 12px;
}

#setting {
    display: none;
    margin: 16px 0 4px;
    padding: 12px;
    background: #fff;
    border: 1px solid #e8eaed;
    border-radius: 8px;
}

#setting .row:last-child {
    margin-bottom: 0;
}

#exchange {
    width: 40px;
    height: 40px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: material-primary;
    border-radius: 20px;
    cursor: pointer;
}

#exchange:hover {
    background: material-hover;
}

.set {
    width: 36px;
    height: 28px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: material-muted;
    border-radius: 18px;
}

#arrow-up {
    display: none;
}

#setting-switch {
    height: 28px;
    justify-content: center;
    margin: 4px 0 0;
    cursor: pointer;
}

#setting-switch:hover .set {
    color: material-on-surface;
    background: material-hover;
}

footer {
    padding: 10px 16px 14px;
    background: #fff;
    color: material-muted;
    text-align: center;
    font-size: 11px;
}

footer a {
    color: material-muted;
}

.multiple {
    flex: 1 1 60%;
    display: inline-block;
}

.select {
    background-color: #fff;
    appearance: none;
}

.option {
    line-height: 20px;
}

i {
    max-height: 40px;
}

/* Material 3 expanded pass */
html,
body {
    background: #f8fafd;
}

.frame {
    padding: 18px;
    background:
        linear-gradient(180deg, #fff, #f8fafd 90px),
        #fff;
}

.row {
    gap: 12px;
}

select,
#translate_input {
    min-height: 44px;
    border: 0;
    background: #f1f4f8;
    border-radius: 8px;
    box-shadow: inset 0 0 0 1px #dde6ef;
    font-weight: 500;
}

select:hover,
#translate_input:hover {
    background: #e6edf4;
}

select:focus,
#translate_input:focus {
    background: #fff;
    border-color: transparent;
    box-shadow: inset 0 0 0 2px material-primary, 0 0 0 4px rgba(11, 87, 208, 0.12);
}

#translateSubmit {
    min-height: 44px;
    border: 0;
    border-radius: 999px;
    background: #0b57d0;
    box-shadow: 0 1px 2px rgba(60, 64, 67, 0.18);
    font-weight: 700;
}

#translateSubmit:hover {
    background: #0842a0;
    box-shadow: 0 2px 6px rgba(60, 64, 67, 0.2);
}

#setting {
    padding: 14px;
    background: #fff;
    border-color: #e1e3e1;
    box-shadow: 0 1px 2px rgba(60, 64, 67, 0.08);
    transition:
        background-color motion-standard,
        border-color motion-standard,
        box-shadow motion-standard;
}

#exchange,
.set {
    border-radius: 999px;
    transition: background-color motion-fast, color motion-fast, box-shadow motion-fast;
}

#exchange:hover,
#setting-switch:hover .set {
    color: #0b57d0;
    background: rgba(11, 87, 208, 0.08);
}

footer {
    background: #f8fafd;
    border-top: 1px solid #e1e3e1;
    transition: background-color motion-standard, border-color motion-standard, color motion-standard;
}

.switch,
.radio,
.checkbox {
    transition:
        background-color motion-fast,
        border-color motion-fast,
        box-shadow motion-fast,
        opacity motion-fast;
}

@media (prefers-color-scheme: dark) {
    html,
    body {
        background: #15191d;
        color: #e8eaed;
        color-scheme: dark;
    }

    .frame {
        background:
            linear-gradient(180deg, #20262d, #1b2026 90px),
            #1b2026;
    }

    .switch-label,
    .option {
        color: #e8eaed;
    }

    select,
    #translate_input {
        color: #e8eaed;
        background: #242a31;
        box-shadow: inset 0 0 0 1px #3d4651;
    }

    select:hover,
    #translate_input:hover {
        background: #2a3038;
    }

    select:focus,
    #translate_input:focus {
        background: #1b2026;
        box-shadow: inset 0 0 0 2px #8ab4f8, 0 0 0 4px rgba(138, 180, 248, 0.18);
    }

    #translate_input::placeholder {
        color: #9aa0a6;
    }

    #translateSubmit {
        color: #0b1f3a;
        background: #a8c7fa;
        box-shadow: 0 1px 2px rgba(0, 0, 0, 0.28);
    }

    #translateSubmit:hover {
        background: #d3e3fd;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.32);
    }

    #hint_message {
        color: #f2b8b5;
    }

    #setting {
        background: #20262d;
        border-color: #343b44;
        box-shadow: 0 1px 2px rgba(0, 0, 0, 0.24);
    }

    #exchange,
    .set {
        color: #a8c7fa;
    }

    #exchange:hover,
    #setting-switch:hover .set {
        color: #d3e3fd;
        background: rgba(168, 199, 250, 0.14);
    }

    footer {
        background: #15191d;
        border-top-color: #343b44;
        color: #bdc1c6;
    }

    footer a {
        color: #bdc1c6;
    }

    .radio,
    .checkbox {
        background-color: #1b2026;
        border-color: #9aa0a6;
    }

    .radio:checked,
    .checkbox:checked {
        background-color: #8ab4f8;
        border-color: #8ab4f8;
    }

    .radio:checked:before {
        background-color: #0b1f3a;
    }

    .checkbox:checked:after {
        border-color: #0b1f3a;
    }

    .switch {
        background: #343b44;
        border-color: #9aa0a6;
    }

    .switch:before {
        background-color: #343b44;
    }

    .switch:after {
        background-color: #c4c7c5;
    }

    .switch:checked {
        background-color: #1f3b68;
        border-color: #8ab4f8;
    }

    .switch:checked:after {
        background-color: #8ab4f8;
    }
}

@media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
        animation-duration: 1ms !important;
        animation-iteration-count: 1 !important;
        scroll-behavior: auto !important;
        transition-duration: 1ms !important;
    }
}
