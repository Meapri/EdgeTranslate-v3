// ════════════════════════════════════════════════════════════════════════
// EdgeTranslate — Shared design tokens
//
// Single source of truth for the entire extension. Tokens use modern
// Chrome-native CSS only (light-dark, color-mix, linear() easing,
// accent-color, scrollbar-color). No M3 vestiges, no manual @media dark
// blocks anywhere downstream.
// ════════════════════════════════════════════════════════════════════════

:root
    color-scheme: unquote('light dark')
    accent-color: unquote('light-dark(#007aff, #0a84ff)')
    scrollbar-color: unquote('light-dark(rgba(60,60,67,.36), rgba(235,235,245,.36)) transparent')
    scrollbar-width: thin

    // ─── iOS 26 system palette ─────────────────────────────────────────
    --ios-tint: unquote('light-dark(#007aff, #0a84ff)')
    --ios-system-blue: unquote('light-dark(#007aff, #0a84ff)')
    --ios-system-green: unquote('light-dark(#34c759, #30d158)')
    --ios-system-indigo: unquote('light-dark(#5856d6, #5e5ce6)')
    --ios-system-orange: unquote('light-dark(#ff9500, #ff9f0a)')
    --ios-system-pink: unquote('light-dark(#ff2d55, #ff375f)')
    --ios-system-purple: unquote('light-dark(#af52de, #bf5af2)')
    --ios-system-red: unquote('light-dark(#ff3b30, #ff453a)')
    --ios-system-teal: unquote('light-dark(#30b0c7, #40c8e0)')
    --ios-system-yellow: unquote('light-dark(#ffcc00, #ffd60a)')

    // ─── Labels ────────────────────────────────────────────────────────
    --ios-label: unquote('light-dark(rgba(0,0,0,.88), rgba(255,255,255,.92))')
    --ios-label-secondary: unquote('light-dark(rgba(60,60,67,.6), rgba(235,235,245,.6))')
    --ios-label-tertiary: unquote('light-dark(rgba(60,60,67,.3), rgba(235,235,245,.3))')

    // ─── Fills ─────────────────────────────────────────────────────────
    --ios-fill-1: unquote('light-dark(rgba(120,120,128,.2), rgba(120,120,128,.36))')
    --ios-fill-2: unquote('light-dark(rgba(120,120,128,.16), rgba(120,120,128,.32))')
    --ios-fill-3: unquote('light-dark(rgba(120,120,128,.12), rgba(118,118,128,.24))')
    --ios-fill-4: unquote('light-dark(rgba(120,120,128,.08), rgba(118,118,128,.18))')

    // ─── Liquid Glass material ─────────────────────────────────────────
    --glass: unquote('light-dark(rgba(255,255,255,.42), rgba(28,28,30,.5))')
    --glass-thick: unquote('light-dark(rgba(255,255,255,.6), rgba(28,28,30,.65))')
    --glass-thin: unquote('light-dark(rgba(255,255,255,.28), rgba(28,28,30,.38))')
    --glass-stroke: unquote('light-dark(rgba(255,255,255,.7), rgba(255,255,255,.08))')
    --glass-shine: unquote('inset 0 1px 0 rgba(255,255,255,.45), inset 0 -1px 0 rgba(0,0,0,.05)')
    --glass-drop: 0 12px 32px rgba(0, 0, 0, .14), 0 32px 64px -16px rgba(0, 0, 0, .22)
    --glass-blur: blur(48px) saturate(220%) brightness(1.04)
    --glass-blur-light: blur(28px) saturate(180%)

    // ─── Continuous corners (iOS) ──────────────────────────────────────
    --r-xs: 8px
    --r-sm: 12px
    --r-md: 16px
    --r-lg: 22px
    --r-xl: 28px
    --r-2xl: 34px
    --r-pill: 9999px

    // ─── Font stack ────────────────────────────────────────────────────
    --font: unquote('-apple-system, BlinkMacSystemFont, "SF Pro Text", "SF Pro Display", system-ui, "Segoe UI", Roboto, sans-serif')

    // ─── Motion (Chrome-native linear() springs) ───────────────────────
    --spring: linear(0, .046 4%, .196 9%, .523 19%, .81 28%, 1.012 37%, 1.099 45%, 1.108 53%, 1.069 64%, 1.014 76%, .987 86%, 1)
    --spring-snappy: linear(0, .083 6%, .286 12%, .572 21%, .844 30%, 1.014 38%, 1.069 44%, 1.072 51%, 1.038 60%, 1.011 69%, .998 78%, .999 90%, 1)
    --emphasized: linear(0, .005, .018 1.5%, .066 3.7%, .171 7.5%, .346 13.6%, .547 21%, .722 29.4%, .853 38.4%, .937 47.7%, .978 56.8%, .997 67.4%, 1)


// ─── Global resets ───────────────────────────────────────────────────────
*,
*::before,
*::after
    box-sizing: border-box

:focus-visible
    outline: none
    box-shadow: unquote('0 0 0 3px color-mix(in oklab, var(--ios-tint) 35%, transparent)')

::selection
    background-color: unquote('color-mix(in oklab, var(--ios-tint) 28%, transparent)')
    color: unquote('var(--ios-label)')

@media (prefers-reduced-motion: reduce)
    *
        animation-duration: .01ms !important
        transition-duration: .01ms !important
        scroll-behavior: auto !important
